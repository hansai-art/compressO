{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "editor.defaultFormatter": "biomejs.biome",
  "cSpell.words": [
    "appimage",
    "compresso",
    "FFPROBE",
    "gifsicle",
    "gifski",
    "heroui",
    "imagequant",
    "jpegoptim",
    "matroska",
    "msvideo",
    "nsis",
    "pngquant",
    "tauri",
    "Triggerer",
    "Unlisten",
    "valtio"
  ],
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[svg]": {
    "editor.defaultFormatter": "jock.svg"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  }
}
