---
import { motion } from 'framer-motion'

import aboutImage from '../assets/about.jpg'
import compressoLogo from '../assets/compresso.png'
import featuresImage from '../assets/features.jpg'
import heroImage from '../assets/hero.jpg'
import OGImage from '../assets/og.jpg'
import privateImage from '../assets/private.jpg'
import BaseHead from '../components/BaseHead.astro'
import Footer from '../components/Footer.astro'
import Header from '../components/Header.astro'
import HeroAnimatedContent from '../components/HeroAnimatedContent'
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts'
import {
  fetchGitHubStars,
  getDownloadAssets,
  getLatestRelease,
} from '../utils/github'

const latestRelease = await getLatestRelease()
const downloads = getDownloadAssets(latestRelease.tag_name)
const githubStars = await fetchGitHubStars()
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <BaseHead
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      image={OGImage}
    />
  </head>
  <body>
    <Header />
    <section class="hero w-[95vw]! xl:w-[90vw]!">
      <div class="hero-content">
        <HeroAnimatedContent client:visible />
        <p>
          CompressO 是一款完全免費、開源的影片／圖片壓縮工具，
          支援 Mac、Windows 與 Linux。
          <br />
          不用註冊、不上傳雲端、不做追蹤。所有壓縮都在你的電腦本機完成，
          兼顧效率與隱私。
        </p>
        <div class="cta-group">
          <a href="#downloads" class="btn btn-primary text-zinc-900!">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            立即下載
          </a>
          <a
            href="https://github.com/codeforreal1/compressO"
            class="btn btn-secondary"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            前往 GitHub <span id="github-stars">{githubStars ? `⭐️ ${githubStars.toLocaleString()}` : ""}</span>
          </a>
        </div>
        <div class="hero-image rounded-[25px]! xl:rounded-[100px]!">
          <img src={heroImage.src} alt="CompressO Interface" />
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">
            強大壓縮能力。<br />
            <span class="gradient-text">品質不妥協</span>
          </h2>
          <p class="section-subtitle">
            CompressO 結合高品質壓縮演算法，並把隱私與易用性放在第一位。
          </p>
        </div>

        <div class="feature-grid">
          <div class="feature-card">
            <div class="feature-icon">🔒</div>
            <h3>100% 離線</h3>
            <p>
              檔案不會離開你的裝置，所有壓縮都在本機進行，完整保護隱私與安全。
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">⚡</div>
            <h3>高速處理</h3>
            <p>採用最新 FFmpeg，幾秒內就能完成影片壓縮。</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">🎯</div>
            <h3>智慧壓縮</h3>
            <p>
              在盡量保留畫質的前提下大幅縮小檔案，非常適合分享與保存。
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">🎨</div>
            <h3>簡單介面</h3>
            <p>
              拖曳、貼上或點選即可開始壓縮，不必研究複雜參數，新手也能快速上手。
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">🌐</div>
            <h3>多格式支援</h3>
            <p>
              支援 MP4、MOV、AVI 等主流格式，也能依需求輸出成不同格式。
            </p>
          </div>

          <div class="feature-card">
            <div class="feature-icon">💎</div>
            <h3>畫質控制</h3>
            <p>
              可微調壓縮設定，在檔案大小與畫質之間取得平衡，儲存前也能先預覽。
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="section showcase-section">
      <div class="container">
        <div class="showcase-content">
          <div class="showcase-text">
            <span class="section-tag">強大功能</span>
            <h2>你需要的 <span class="gradient-text">功能</span><br />都在這裡！</h2>
            <p>
              CompressO 不只是單純壓縮，更是一套同時適合進階使用者與新手的
              完整影音處理工具。
            </p>
            <ul class="feature-list feature-list-vertical" id="featureList">
              <li>
                <div class="feature-item-content">
                  <strong>批次壓縮</strong>
                  <span
                    >可同時處理多個影片與圖片，並具備智慧佇列管理</span
                  >
                </div>
              </li>
              <li>
                <div class="feature-item-content">
                  <strong>影片編輯</strong>
                  <span
                    >壓縮前可先裁切片段、分割、裁剪、旋轉、翻轉與縮放影片</span
                  >
                </div>
              </li>
              <li>
                <div class="feature-item-content">
                  <strong>圖片編輯</strong>
                  <span
                    >壓縮前可先裁剪、旋轉、翻轉與調整圖片尺寸</span
                  >
                </div>
              </li>
              <li>
                <div class="feature-item-content">
                  <strong>影片控制</strong>
                  <span
                    >可自訂編碼器、畫質、尺寸、解析度、FPS、速度與輸出格式</span
                  >
                </div>
              </li>
              <li>
                <div class="feature-item-content">
                  <strong>圖片控制</strong>
                  <span
                    >可調整 JPEG、PNG、WebP、GIF 的畫質、格式與最佳化設定</span
                  >
                </div>
              </li>
              <li>
                <div class="feature-item-content">
                  <strong>音訊控制</strong>
                  <span
                    >可調整編碼器、音量、聲道、位元率，並選擇保留的音軌</span
                  >
                </div>
              </li>
              <li>
                <div class="feature-item-content">
                  <strong>剪貼簿支援</strong>
                  <span
                    >可直接從剪貼簿貼上影片、圖片或資料夾，立即批次處理</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>格式轉換</strong>
                  <span
                    >可輕鬆在圖片格式（JPEG、PNG、WebP、GIF）與影片格式間轉換</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>SVG 轉換</strong>
                  <span
                    >可把 SVG 轉成 PNG、JPEG、WebP，並調整進階點陣化設定</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>GIF 工具</strong>
                  <span
                    >可由影片產生 GIF，也能壓縮既有 GIF 並盡量保留品質</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>比較滑桿</strong>
                  <span
                    >可用互動式前後比較滑桿查看原檔與壓縮後差異</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>拖曳加入</strong>
                  <span
                    >可直接拖入整個資料夾，自動批次壓縮其中的影片與圖片</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>檔案總管整合</strong>
                  <span
                    >可在檔案管理器中右鍵影片或圖片，直接用 CompressO 開啟</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>完整中繼資料</strong>
                  <span
                    >可查看尺寸、格式、EXIF、串流、字幕與章節等完整資訊</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>複製到剪貼簿</strong>
                  <span
                    >可把壓縮後的影片或圖片直接複製到剪貼簿，方便立即貼上</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>中繼資料編輯</strong>
                  <span
                    >可編輯影片的標題、作者、專輯、年份、類型、描述、版權等欄位</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>圖片中繼資料</strong>
                  <span
                    >壓縮圖片時可保留 EXIF 與其他中繼資料</span
                  >
                </div>
              </li>
              <li class="feature-hidden">
                <div class="feature-item-content">
                  <strong>自訂縮圖</strong>
                  <span
                    >可設定自訂縮圖，讓檔案管理器顯示你指定的影片預覽圖</span
                  >
                </div>
              </li>
            </ul>
            <button class="show-all-btn" id="showAllBtn"
              >查看更多功能</button
            >
          </div>
          <div class="showcase-visual">
            <img
              src={featuresImage.src}
              alt="CompressO Features"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="section showcase-section">
      <div class="container">
        <div class="showcase-content">
          <div class="showcase-visual">
             <img src={privateImage.src} alt="隱私優先" loading="lazy" />
          </div>
          <div class="showcase-text">
             <span class="section-tag">隱私優先</span>
             <h2>你的檔案只屬於你。<br />
               <span class="gradient-text">一直都是！</span>
             </h2>
             <p>
               不像線上壓縮服務，CompressO 不會上傳你的檔案。不用帳號、不做追蹤、
               不收集資料，只有尊重隱私的本機壓縮。
             </p>
             <ul class="feature-list">
               <li>不需要網路連線</li>
               <li>不需要帳號或註冊</li>
               <li>沒有檔案大小限制</li>
               <li>沒有浮水印</li>
               <li>沒有任何追蹤</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="section showcase-section">
      <div class="container">
        <div class="showcase-content">
          <div class="showcase-text">
             <span class="section-tag">開源精神</span>
             <h2>免費且開源。<br />
               <span class="gradient-text">永久如此！</span>
             </h2>
             <p>
               CompressO 是完整開源軟體，原始碼公開在 GitHub 上，你可以審查、
               參與貢獻，甚至 fork 成自己的版本。
             </p>
             <ul class="feature-list">
               <li>採用 MIT 授權，可自由使用</li>
               <li>開發過程透明公開</li>
               <li>社群驅動功能演進</li>
               <li>持續更新與改進</li>
               <li>沒有隱藏費用與付費分級</li>
            </ul>
            <a
              href="https://github.com/codeforreal1/compressO"
              class="github-link"
              style="margin-top: 24px;"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
               到 GitHub 按星
            </a>
          </div>
          <div class="showcase-visual">
             <img src={aboutImage.src} alt="開源軟體" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <section class="section cta-section">
      <img
          src={compressoLogo.src}
          alt="Compresso Logo"
          class="w-30 h-auto block  mx-auto!"
      />
      <div class="container">
         <h2 class="gradient-text">準備好開始壓縮影片與圖片了嗎？</h2>
        <div id="downloads" class="downloads-section">
           <h3>直接下載</h3>
          <div class="downloads-grid">
            <div class="download-column">
              <div class="download-os-header">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="#000000"
                >
                  <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
                  <g
                    id="SVGRepo_tracerCarrier"
                    stroke-linecap="round"
                    stroke-linejoin="round"></g>
                  <g id="SVGRepo_iconCarrier">
                    <path
                      fill="#AAA"
                      fill-rule="evenodd"
                      d="M15.3007013,3.832 C16.1387013,2.818 16.7027013,1.405 16.5487013,0 C15.3407013,0.049 13.8797013,0.805 13.0137013,1.819 C12.2367013,2.717 11.5567013,4.154 11.7407013,5.531 C13.0867013,5.636 14.4627013,4.847 15.3007013,3.832 M18.3207013,12.75 C18.3547013,16.382 21.5067013,17.591 21.5417013,17.607 C21.5157013,17.692 21.0387013,19.329 19.8807013,21.02 C18.8807013,22.482 17.8427013,23.939 16.2067013,23.969 C14.5997013,23.998 14.0837013,23.016 12.2457013,23.016 C10.4097013,23.016 9.83570131,23.939 8.31370131,23.998 C6.73570131,24.058 5.53370131,22.417 4.52470131,20.961 C2.46370131,17.981 0.888701307,12.541 3.00370131,8.869 C4.05470131,7.045 5.93170131,5.89 7.96970131,5.861 C9.51970131,5.831 10.9827013,6.904 11.9307013,6.904 C12.8777013,6.904 14.6557013,5.614 16.5247013,5.803 C17.3077013,5.836 19.5037013,6.119 20.9147013,8.184 C20.8007013,8.254 18.2937013,9.714 18.3207013,12.75"
                    >
                    </path>
                  </g>
                </svg>
                macOS
              </div>
              <div
                class="download-btn"
                style="cursor: default; background: rgba(255, 255, 255, 0.03); border-style: dashed;"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  xmlns:xlink="http://www.w3.org/1999/xlink"
                  width="20"
                  height="100%"
                  viewBox="0 0 180 271"
                  version="1.1"
                  xml:space="preserve"
                  style="fill-rule:evenodd;clip-rule:evenodd;stroke-linejoin:round;"
                >
                  <g id="Group" transform="matrix(1,0,0,1,5.782,3.414)">
                    <g id="Path" transform="matrix(1,0,0,1,13,0)">
                      <g transform="matrix(1,0,0,1,24,0)">
                        <path
                          d="M31.758,46.916C32.498,23.429 24.586,9.582 1.841,0.435C-4.624,23.049 22.066,43.9 31.758,46.916Z"
                          style="fill:rgb(209,211,212);stroke:black;stroke-width:4.79px;"
                        ></path>
                      </g>
                      <path
                        d="M117.441,86.72C118.181,67.434 113.31,59.65 109.654,54.084C105.945,48.892 97.045,40.732 86.11,40.39C75.769,40.066 73.282,45.782 63.742,46.127C62.178,28.755 75.289,19.222 75.289,19.222C75.289,19.222 71.704,14.155 68.738,12.917C64.472,16.708 52.73,29.353 55.447,45.625C46.669,43.947 40.473,38.923 31.252,40.737C18.69,43.209 8.335,50.804 2.433,67.47C-3.468,84.137 4.516,103.581 6.252,109.134C7.989,114.692 20.836,138.298 30.905,141.772C40.972,145.247 40.975,143.681 46.357,141.599C51.74,139.516 59.897,135.697 71.879,140.038C83.854,144.377 85.416,145.417 92.879,140.557C100.348,135.698 110.067,120.595 112.322,116.254C114.579,111.915 115.795,109.657 116.492,107.401C123.748,103.78 116.775,104.004 117.441,86.72Z"
                        style="fill:rgb(209,211,212);stroke:black;stroke-width:4.79px;"
                      ></path>
                    </g>
                    <g transform="matrix(1,0,0,1,4,112)">
                      <path
                        id="Shape"
                        d="M145.932,115.67C150.717,115.687 155.312,113.799 158.701,110.422C162.091,107.045 163.996,102.457 163.996,97.672C163.998,79.399 163.998,51.162 163.998,32.839C163.998,28.065 162.102,23.487 158.726,20.111C155.35,16.735 150.772,14.839 145.998,14.839L131.16,14.839C128.951,14.839 127.16,13.048 127.16,10.839L127.16,1.409L10.13,1.409C10.13,1.409 10.388,121.948 10.425,139.622C10.428,140.985 11.125,142.254 12.275,142.987C17.487,146.005 34.196,151.737 69.279,151.737C105.104,151.737 121.118,144.063 125.703,140.598C126.614,139.842 127.141,138.72 127.141,137.536C127.16,133.711 127.16,124.848 127.16,119.612C127.16,118.537 127.593,117.507 128.361,116.755C129.129,116.002 130.168,115.591 131.243,115.613C135.644,115.675 140.917,115.684 145.932,115.67ZM127.16,35.864C127.16,34.538 127.687,33.266 128.624,32.328C129.562,31.391 130.834,30.864 132.16,30.864L144.898,30.864C146.224,30.864 147.496,31.391 148.434,32.328C149.371,33.266 149.898,34.538 149.898,35.864L149.898,94.049C149.898,95.375 149.371,96.647 148.434,97.585C147.496,98.522 146.224,99.049 144.898,99.049L132.16,99.049C130.834,99.049 129.562,98.522 128.624,97.585C127.687,96.647 127.16,95.375 127.16,94.049L127.16,35.864Z"
                        style="fill:white;fill-rule:nonzero;stroke:black;stroke-width:4.79px;"
                      ></path>
